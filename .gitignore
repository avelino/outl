# Cargo build artifacts
/target
**/target
debug

# JS/TS frontend (bun workspaces — outl-frontend-shared, outl-mobile, outl-desktop)
node_modules/
**/node_modules/
dist/
**/dist/
.vite/
**/.vite/

# Tauri auto-generated capability schemas (regenerated on every build by tauri-build).
# `gen/apple/` (mobile) is manual config and intentionally committed.
**/src-tauri/gen/schemas/

# Backups from rustfmt
**/*.rs.bk

# MSVC Windows builds
*.pdb

# cargo-mutants
**/mutants.out*/

# cargo-llvm-cov / tarpaulin
/coverage
*.profraw
lcov.info

# JetBrains / VS Code
.idea/
.vscode/
*.iml

# macOS
.DS_Store

# Local outl workspace for dev/test
/playground/
/.outl-test/
/.outl/
/lerolero/

# Scratch dir for screenshots, captures, throwaway artefacts
/.tmp/

# Generated SQLite WAL files (when testing)
*.db-wal
*.db-shm

note-example/

# Criterion bench artefacts (regenerated on every run, large)
**/criterion/

# Claude Code session-local state (process locks, etc.)
.claude/*.lock

# Python bytecode (CI scripts run uncached; locally we may have caches)
__pycache__/
*.pyc

# Local-only helper scripts (per-machine TestFlight smoke tests, etc.)
# Versioned scripts live elsewhere; anything matching `local-*` is
# treated as personal scratch and never goes to the repo.
scripts/local-*.sh
