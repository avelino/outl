{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "outl",
  "version": "0.2.0",
  "identifier": "app.outl.mobile-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "outl",
        "label": "main",
        "width": 390,
        "height": 844
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "CPEEKT3E77"
    }
  }
}
