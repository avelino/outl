{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "os:allow-hostname",
    "deep-link:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "mailto:*" }
      ]
    }
  ]
}
